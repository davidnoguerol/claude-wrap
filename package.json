{
  "name": "claude-wrap",
  "version": "0.0.0",
  "description": "Drive coding-agent CLIs (Claude Code, Codex) via the terminal on subscription auth; expose a structured API to consumer projects.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/postinstall.mjs",
    "probe": "node tests/interactive-probe.mjs",
    "test:phase1": "node tests/phase1-accept.mjs"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.6.0"
  }
}
